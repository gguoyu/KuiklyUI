{
  "all": true,
  "include": ["instrumented/**/*.js"],
  "exclude": [
    "**/*.spec.js",
    "**/*.test.js",
    "**/node_modules/**",
    "**/test/**",
    "**/tests/**"
  ],
  "reporter": ["text", "html", "lcov", "json"],
  "report-dir": "reports/coverage",
  "temp-dir": ".nyc_output",
  "sourceMap": true,
  "check-coverage": true,
  "lines": 70,
  "functions": 70,
  "statements": 70,
  "branches": 55,
  "per-file": false,
  "watermarks": {
    "lines": [70, 80],
    "functions": [70, 80],
    "branches": [55, 75],
    "statements": [70, 80]
  }
}
