{
  "all": false,
  "include": [
    "core-render-web/base/src/jsMain/kotlin/**/*.kt",
    "core-render-web/h5/src/jsMain/kotlin/**/*.kt"
  ],
  "exclude": [
    "**/*.spec.js",
    "**/*.test.js",
    "**/node_modules/**",
    "**/test/**",
    "**/tests/**"
  ],
  "reporter": ["text", "html", "lcov", "json", "json-summary"],
  "report-dir": "reports/coverage",
  "temp-dir": ".nyc_output",
  "sourceMap": true,
  "check-coverage": true,
  "lines": 70,
  "functions": 70,
  "statements": 70,
  "branches": 55,
  "per-file": false,
  "watermarks": {
    "lines": [70, 80],
    "functions": [70, 80],
    "branches": [55, 75],
    "statements": [70, 80]
  },
  "parser-plugins": [
    "variableDeclaration", 
    "assignmentExpression"
  ]
}