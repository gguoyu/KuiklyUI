{
  "name": "kuikly-web-e2e",
  "version": "1.0.0",
  "description": "Kuikly Web E2E Testing with Playwright",
  "scripts": {
    "setup": "node scripts/setup-fonts.mjs",
    "serve": "node scripts/serve.js",
    "serve:dev": "BUILD_TYPE=developmentExecutable node scripts/serve.js",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:static": "node scripts/kuikly-test.mjs --level static",
    "test:functional": "node scripts/kuikly-test.mjs --level functional",
    "test:visual": "node scripts/kuikly-test.mjs --level visual",
    "test:hybrid": "node scripts/kuikly-test.mjs --level hybrid",
    "test:modules": "playwright test tests/functional/modules",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:smoke": "playwright test tests/static/smoke-static.spec.ts",
    "report": "playwright show-report",
    "codegen": "playwright codegen http://localhost:8080",
    "install:browsers": "playwright install",
    "verify": "node verify-phase1.mjs",
    "coverage": "node scripts/coverage-report.mjs",
    "coverage:check": "node scripts/coverage-report.mjs --check",
    "coverage:js-no-sourcemap": "node scripts/coverage-js-no-sourcemap-report.mjs",
    "kuikly-test": "node scripts/kuikly-test.mjs"
  },
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "kuikly"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "monocart-coverage-reports": "^2.12.10",
    "typescript": "^5.3.0"
  }
}
