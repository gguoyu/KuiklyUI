{
  "categoryDefaults": {
    "default": "default",
    "interactions": "interaction-generic",
    "animations": "animation-generic",
    "modules": "module-generic",
    "composite": "default"
  },
  "categoryRepairDefaults": {
    "default": {
      "templateProfile": "generic-repair",
      "strategy": "rewrite-managed-spec-to-light-smoke"
    },
    "interactions": {
      "templateProfile": "interaction-generic-repair",
      "strategy": "rewrite-interaction-managed-spec-to-light-smoke"
    },
    "animations": {
      "templateProfile": "animation-generic-repair",
      "strategy": "rewrite-animation-managed-spec-to-light-smoke"
    },
    "modules": {
      "templateProfile": "module-generic-repair",
      "strategy": "rewrite-module-managed-spec-to-light-smoke"
    },
    "composite": {
      "templateProfile": "generic-repair",
      "strategy": "rewrite-composite-managed-spec-to-light-smoke"
    }
  },
  "pageProfiles": {
    "ListScrollTestPage": {
      "defaultTemplateProfile": "interaction-list-scroll",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-list-scroll"
            ]
          },
          "templateProfile": "interaction-list-scroll-lite",
          "strategy": "reduce-scroll-depth-and-assertions"
        },
        {
          "templateProfile": "interaction-list-scroll-lite",
          "strategy": "reuse-list-scroll-template"
        }
      ]
    },
    "PageListTestPage": {
      "defaultTemplateProfile": "interaction-page-list",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-page-list"
            ],
            "failureCategories": [
              "ELEMENT_NOT_FOUND"
            ]
          },
          "templateProfile": "interaction-page-list-tab-only",
          "strategy": "rewrite-to-tab-driven-page-switch"
        },
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-page-list"
            ],
            "messageIncludes": [
              "bounding box",
              "not visible"
            ]
          },
          "templateProfile": "interaction-page-list-tab-only",
          "strategy": "rewrite-to-tab-driven-page-switch"
        },
        {
          "templateProfile": "interaction-page-list",
          "strategy": "reuse-page-list-template"
        }
      ]
    },
    "EventCaptureTestPage": {
      "defaultTemplateProfile": "interaction-event-capture",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-event-capture"
            ]
          },
          "templateProfile": "interaction-generic-repair",
          "strategy": "rewrite-event-capture-to-reset-smoke"
        }
      ]
    },
    "GestureTestPage": {
      "defaultTemplateProfile": "interaction-gesture",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-gesture"
            ],
            "failureCategories": [
              "ELEMENT_NOT_FOUND",
              "ASSERTION_FAILED",
              "TIMEOUT"
            ]
          },
          "templateProfile": "interaction-generic-repair",
          "strategy": "rewrite-gesture-to-state-summary-smoke"
        }
      ]
    },
    "ModalTestPage": {
      "defaultTemplateProfile": "interaction-modal",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-modal"
            ],
            "failureCategories": [
              "ELEMENT_NOT_FOUND",
              "ASSERTION_FAILED"
            ]
          },
          "templateProfile": "interaction-generic-repair",
          "strategy": "rewrite-modal-to-result-summary-smoke"
        }
      ]
    },
    "FormTestPage": {
      "defaultTemplateProfile": "interaction-form",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-form"
            ],
            "failureCategories": [
              "ASSERTION_FAILED",
              "ELEMENT_NOT_FOUND"
            ]
          },
          "templateProfile": "generic-repair",
          "strategy": "rewrite-form-to-validation-smoke"
        }
      ]
    },
    "SearchTestPage": {
      "defaultTemplateProfile": "interaction-search",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "interaction-search"
            ],
            "failureCategories": [
              "ASSERTION_FAILED",
              "ELEMENT_NOT_FOUND"
            ]
          },
          "templateProfile": "interaction-generic-repair",
          "strategy": "rewrite-search-to-selection-smoke"
        }
      ]
    },
    "JSFrameAnimTestPage": {
      "defaultTemplateProfile": "animation-jsframe",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "animation-jsframe"
            ]
          },
          "templateProfile": "animation-jsframe-state-only",
          "strategy": "rewrite-to-state-driven-animation-checks"
        },
        {
          "templateProfile": "animation-jsframe-state-only",
          "strategy": "reuse-jsframe-animation-template"
        }
      ]
    },
    "PropertyAnimTestPage": {
      "defaultTemplateProfile": "animation-property",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "animation-property"
            ]
          },
          "templateProfile": "animation-property-toggle-only",
          "strategy": "rewrite-to-toggle-state-assertions"
        },
        {
          "templateProfile": "animation-property-toggle-only",
          "strategy": "reuse-property-animation-template"
        }
      ]
    },
    "NetworkModuleTestPage": {
      "defaultTemplateProfile": "module-network",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "module-network"
            ]
          },
          "templateProfile": "module-network-smoke",
          "strategy": "rewrite-to-shorter-network-coverage-path"
        },
        {
          "templateProfile": "module-network-smoke",
          "strategy": "reuse-network-module-template"
        }
      ]
    },
    "NotifyModuleTestPage": {
      "defaultTemplateProfile": "module-notify",
      "repairProfiles": [
        {
          "match": {
            "currentTemplateProfiles": [
              "module-notify"
            ],
            "failureCategories": [
              "ASSERTION_FAILED",
              "ELEMENT_NOT_FOUND"
            ]
          },
          "templateProfile": "module-generic-repair",
          "strategy": "rewrite-notify-to-count-smoke"
        }
      ]
    }
  }
}